---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';
import PrevNextPost from '../components/PrevNextPost.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import Comments from '../components/Comments.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { getCanonicalTags } from '../utils/taxonomy.mjs';

interface Props {
  title: string;
  date: string;
  description?: string;
  seoTitle?: string;
  seoDescription?: string;
  tags?: string[];
  lang?: string;
  featuredImage?: string;
  lastRevision?: string;
  updatedDate?: string;
  previous?: { slug: string; title: string };
  next?: { slug: string; title: string };
  relatedPosts?: { slug: string; title: string; description?: string }[];
  readingTime: number;
  slug: string;
}

const {
  title,
  date,
  description,
  seoTitle,
  seoDescription,
  tags = [],
  lang = 'en',
  featuredImage,
  lastRevision,
  updatedDate,
  previous,
  next,
  relatedPosts = [],
  readingTime,
  slug,
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-GB', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});
const canonicalTags = getCanonicalTags(tags);
---
<BaseLayout
  title={seoTitle || title}
  description={seoDescription || description}
  type="article"
  publishedDate={date}
  updatedDate={updatedDate}
  lang={lang}
  image={featuredImage}
  tags={canonicalTags.map((tag) => tag.label)}
>
  <article>
    <h1>{title}</h1>
    <div class="post-meta">
      By <a href="/about">Maxi</a> · <time datetime={date}>{formattedDate}</time> · {readingTime} min read
    </div>

    {canonicalTags.length > 0 && (
      <div class="tags">
        {canonicalTags.map((tag) => <TagBadge tag={tag.label} />)}
      </div>
    )}

    {featuredImage && (
      <div class="featured-image">
        <img src={featuredImage} alt={title} />
      </div>
    )}

    <div class="content">
      <slot />
    </div>

    {lastRevision && (
      <div class="updated">Updated: {lastRevision}</div>
    )}

    <RelatedPosts posts={relatedPosts} />

    <PrevNextPost previous={previous} next={next} />

    <div class="toolbar">
      <a
        href={`https://github.com/neomaxzero/blog/edit/master/src/posts/${slug}.md`}
        target="_blank"
        rel="noopener noreferrer"
        class="suggest-link"
      >
        suggest changes
      </a>
    </div>

    <NewsletterForm />
    <Comments />
  </article>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }
  .post-meta {
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    text-align: left;
    margin-bottom: 1rem;
  }
  .post-meta a {
    color: var(--color-primary);
  }
  .tags {
    margin: 1.125rem 0;
  }
  .featured-image {
    margin: 1.5rem 0;
  }
  .featured-image img {
    width: 100%;
    border-radius: 8px;
  }
  .content {
    margin-top: 1rem;
  }
  .updated {
    font-size: 0.8rem;
    color: var(--color-text);
    text-align: center;
    margin: 1.5rem 0;
  }
  .toolbar {
    display: flex;
    margin-bottom: 2rem;
    margin-top: 4rem;
  }
  .suggest-link {
    color: var(--color-primary);
    font-size: 0.8rem;
  }
  .suggest-link:hover {
    text-decoration: underline;
  }
</style>
