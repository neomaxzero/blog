---
import PostLayout from '../layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';
import { getCanonicalTags } from '../utils/taxonomy.mjs';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  // Sort by date ASC for prev/next computation
  const sorted = posts.sort(
    (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
  );

  function getSlug(post: any) {
    const lang = post.data.lang;
    return lang === 'es' ? `es/${post.id}` : post.id;
  }

  return sorted.map((post, i) => {
    const prev = sorted[i - 1];
    const next = sorted[i + 1];

    return {
      params: { slug: getSlug(post) },
      props: {
        post,
        previous: prev ? { slug: getSlug(prev), title: prev.data.title } : null,
        next: next ? { slug: getSlug(next), title: next.data.title } : null,
      },
    };
  });
}

const { post, previous, next } = Astro.props;
const { Content } = await render(post);

const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

function getSlug(p: any) {
  const lang = p.data.lang;
  return lang === 'es' ? `es/${p.id}` : p.id;
}

const currentTags = getCanonicalTags(post.data.tags || []).map((tag) => tag.slug);
const currentTopic = (post.data.topic || '').toLowerCase();
const allPosts = await getCollection('posts');

const relatedPosts = allPosts
  .filter((candidate) => candidate.id !== post.id && candidate.data.lang === post.data.lang)
  .map((candidate) => {
    const candidateTags = getCanonicalTags(candidate.data.tags || []).map((tag) => tag.slug);
    const sharedTags = candidateTags.filter((tag) => currentTags.includes(tag)).length;
    const topicScore =
      currentTopic &&
      candidate.data.topic &&
      candidate.data.topic.toLowerCase() === currentTopic
        ? 1
        : 0;

    return {
      slug: getSlug(candidate),
      title: candidate.data.title,
      description: candidate.data.seoDescription || candidate.data.description || candidate.data.subtitle,
      score: sharedTags * 3 + topicScore,
      date: new Date(candidate.data.date).getTime(),
    };
  })
  .filter((candidate) => candidate.score > 0)
  .sort((a, b) => b.score - a.score || b.date - a.date)
  .slice(0, 3);
---
<PostLayout
  title={post.data.title}
  date={post.data.date}
  description={post.data.description}
  seoTitle={post.data.seoTitle}
  seoDescription={post.data.seoDescription}
  tags={post.data.tags}
  lang={post.data.lang}
  lastRevision={post.data.lastRevision}
  updatedDate={post.data.updatedDate}
  previous={previous}
  next={next}
  relatedPosts={relatedPosts}
  readingTime={readingTime}
  slug={post.id}
  featuredImage={post.data.featuredImage ? `/images/posts/${post.data.featuredImage}` : undefined}
>
  <Content />
</PostLayout>
