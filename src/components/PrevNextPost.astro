---
interface Props {
  previous?: { slug: string; title: string };
  next?: { slug: string; title: string };
}

const { previous, next } = Astro.props;
---
<nav class="prev-next" aria-label="Post navigation">
  {previous ? (
    <a href={`/${previous.slug}/`} class="link">&larr; Previous article</a>
  ) : <span />}
  {next ? (
    <a href={`/${next.slug}/`} class="link">Next article &rarr;</a>
  ) : <span />}
</nav>

<style>
  .prev-next {
    display: flex;
    justify-content: space-between;
    margin: 1.875rem 0;
  }
  .link {
    color: var(--color-primary);
  }
  .link:hover {
    text-decoration: underline;
  }
</style>
