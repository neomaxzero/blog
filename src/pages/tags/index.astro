---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getCanonicalTags, isIndexableTagArchive } from '../../utils/taxonomy.mjs';

const posts = await getCollection('posts');

const tagCounts = new Map<string, { label: string; slug: string; count: number; indexable: boolean }>();
posts.forEach((post) => {
  getCanonicalTags(post.data.tags || []).forEach((tag) => {
    const current = tagCounts.get(tag.slug);
    tagCounts.set(tag.slug, {
      label: tag.label,
      slug: tag.slug,
      count: (current?.count || 0) + 1,
      indexable: tag.indexable,
    });
  });
});

const sortedTags = [...tagCounts.values()].sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));
---
<BaseLayout
  title="Frontend Topics and Archives"
  description="Explore frontend articles by topic, including React, performance, SEO, testing, architecture, and selected engineering essays."
>
  <h1>Topics</h1>
  <p class="intro">
    The strongest sections of this blog are frontend engineering, performance, React, testing, architecture, and SEO.
    Narrow topic hubs stay indexable; everything else remains accessible as archive navigation.
  </p>
  <ul class="tag-list">
    {sortedTags.map((tag) => (
      <li>
        <a href={`/tags/${tag.slug}/`} class:list={['tag-link', { active: isIndexableTagArchive(tag, tag.count) }]}>
          {tag.label} <span class="count">({tag.count})</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .intro {
    max-width: 68ch;
    color: var(--color-text-subtle);
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1rem;
  }
  li {
    list-style: none;
    margin-top: 0;
  }
  .tag-link {
    display: inline-block;
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    padding: 0.4rem 0.8rem;
    border-radius: 3px;
    font-size: 0.9rem;
    transition: all 0.15s;
  }
  .tag-link.active {
    background-color: var(--color-primary-16);
  }
  .tag-link:hover {
    background-color: var(--color-primary);
    color: white;
    border-color: transparent;
  }
  .count {
    font-size: 0.8rem;
    opacity: 0.7;
  }
</style>
