---
interface Props {
  title: string;
  date: string;
  subtitle?: string;
  description?: string;
  slug: string;
  featuredImage?: string;
  topic?: string;
  readingTime: number;
  variant?: 'default' | 'editorial';
}

const {
  title,
  date,
  subtitle,
  description,
  slug,
  featuredImage,
  topic,
  readingTime,
  variant = 'default',
} = Astro.props;

const showImage = Boolean(featuredImage);

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---
<a href={`/${slug}/`} class:list={['hero', `hero-${variant}`, !showImage && 'hero-text-only']}>
  {showImage && (
    <div class="hero-image">
      <img src={`/images/posts/${featuredImage}`} alt={title} loading="eager" decoding="async" />
    </div>
  )}
  <div class="hero-body">
    {topic && <span class="topic">{topic}</span>}
    <h2 class="hero-title">{title}</h2>
    {(subtitle || description) && (
      <p class="hero-desc">{subtitle || description}</p>
    )}
    <div class="hero-meta">
      <time datetime={date}>{formattedDate}</time>
      <span class="dot">&middot;</span>
      <span>{readingTime} min read</span>
    </div>
  </div>
</a>

<style>
  .hero {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    margin-bottom: 2.5rem;
  }
  .hero:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }
  :global(html.dark) .hero:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }
  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 8;
    overflow: hidden;
    background-color: var(--color-border);
  }
  .hero-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .hero:hover .hero-image img {
    transform: scale(1.03);
  }
  .hero-body {
    padding: 1.5rem;
  }
  .topic {
    display: inline-block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .hero-title {
    font-size: 1.75rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    color: var(--color-strong);
    letter-spacing: -0.03em;
  }
  .hero-desc {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-text-subtle);
    margin: 0 0 1rem;
    padding: 0;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-subtle);
  }
  .dot {
    opacity: 0.5;
  }

  .hero-editorial {
    margin-bottom: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    box-shadow: none;
  }

  .hero-editorial:hover {
    transform: none;
    box-shadow: none;
  }

  .hero-editorial .hero-image {
    aspect-ratio: 4 / 3;
    background-color: transparent;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-editorial .hero-image img {
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transition: transform 0.35s ease;
  }

  .hero-editorial .hero-body {
    padding: 1.1rem 1.25rem 1.25rem;
  }

  .hero-editorial .topic {
    margin-bottom: 0.35rem;
  }

  .hero-editorial .hero-title {
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    line-height: 1.12;
    letter-spacing: -0.045em;
    max-width: 15ch;
    margin-bottom: 0.55rem;
  }

  .hero-editorial .hero-desc {
    font-size: 0.98rem;
    line-height: 1.55;
    max-width: 58ch;
    margin-bottom: 0;
  }

  .hero-editorial .hero-meta {
    gap: 0.5rem;
    font-size: 0.78rem;
    letter-spacing: 0.01em;
    margin-top: 0.85rem;
  }

  @media (min-width: 769px) {
    .hero-title {
      font-size: 2rem;
    }

    .hero-editorial {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(20rem, 0.85fr);
      gap: 0;
      align-items: start;
    }

    .hero-editorial.hero-text-only {
      display: block;
    }

    .hero-editorial .hero-image {
      aspect-ratio: 1 / 1;
      border-right: 1px solid var(--color-border);
      border-bottom: 0;
    }

    .hero-editorial .hero-body {
      padding: 1.3rem 1.35rem 1.35rem;
    }
  }
</style>
