---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostItem from '../../components/PostItem.astro';
import { getCollection } from 'astro:content';
import { getCanonicalTag, getCanonicalTags, isIndexableTagArchive } from '../../utils/taxonomy.mjs';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  const tagMap: Record<string, any[]> = {};
  posts.forEach((post) => {
    getCanonicalTags(post.data.tags || []).forEach((tag) => {
      const key = tag.slug;
      if (!tagMap[key]) tagMap[key] = [];
      tagMap[key].push({ tag, post });
    });
  });

  return Object.entries(tagMap).map(([kebab, items]) => ({
    params: { tag: kebab },
    props: {
      tag: items[0].tag,
      posts: items.map((i) => i.post).sort(
        (a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
const canonicalTag = getCanonicalTag(tag.label || tag);
const indexable = isIndexableTagArchive(canonicalTag, posts.length);

function getPostSlug(post: any) {
  return post.data.lang === 'es' ? `es/${post.id}` : post.id;
}
---
<BaseLayout
  title={`${canonicalTag.label} articles`}
  description={`Browse ${posts.length} article${posts.length === 1 ? '' : 's'} about ${canonicalTag.label} on Maxi Cespedes' frontend engineering blog.`}
  noindex={!indexable}
>
  <h1>{canonicalTag.label} ({posts.length})</h1>
  <p class="intro">
    {indexable
      ? `This topic hub groups ${canonicalTag.label} articles that contribute to the core frontend knowledge base on the site.`
      : `This archive groups ${canonicalTag.label} posts for navigation, but it is intentionally kept out of search indexing because the topic is still too small or too broad.`}
  </p>
  <ul>
    {posts.map((post: any) => (
      <PostItem
        title={post.data.title}
        date={post.data.date}
        subtitle={post.data.subtitle}
        slug={getPostSlug(post)}
      />
    ))}
  </ul>
</BaseLayout>

<style>
  .intro {
    max-width: 68ch;
    color: var(--color-text-subtle);
  }
</style>
