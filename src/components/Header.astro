---
import ThemeToggle from './ThemeToggle.astro';
---
<header>
  <div class="header-inner">
    <div class="header-content">
      <div>
        <a href="/" class="logo-link">
          <img src="/logo.svg" alt="m4x blog" class="logo" />
          <span class="logo-text">m4x</span>
        </a>
      </div>
      <nav>
        <a href="/tags" class="nav-link">Tags</a>
        <a href="/about" class="nav-link">About</a>
        <ThemeToggle />
      </nav>
    </div>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--header-height, 52px);
    background-color: var(--color-bg-70);
    z-index: 10;
    backdrop-filter: saturate(180%) blur(20px);
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
  }
  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 0;
  }
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .logo {
    height: 28px;
    width: auto;
  }
  .logo-text {
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--color-text-subtle);
    letter-spacing: 0.02em;
  }
  :global(html.dark) .logo {
    filter: invert(1);
  }
  nav {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .nav-link {
    font-size: 0.8rem;
    color: var(--color-text-subtle);
  }
  .nav-link:hover {
    color: var(--color-primary);
  }
</style>
